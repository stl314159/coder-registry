proxmox_api_url: "https://proxmox.example.com:8006"
proxmox_token_id: "user@pam!token-name"
proxmox_token_secret: "CHANGE_ME"
proxmox_ssh_user: "root"
proxmox_ssh_private_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  CHANGE_ME
  -----END OPENSSH PRIVATE KEY-----

# VM sizing (optional — defaults shown)
vm_cpu_cores: 4
vm_memory_mb: 8192
vm_disk_size_gb: 32
